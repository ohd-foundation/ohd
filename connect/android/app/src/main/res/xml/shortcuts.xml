<?xml version="1.0" encoding="utf-8"?>
<!--
  App Shortcuts + App Actions (capability) declarations.

  Two distinct surfaces live here:

  1. `<capability>` — App Actions. Bridges a Built-In Intent (BII) — or a
     `custom.actions.intent.*` — to one of our app intents. This is the
     surface Google Assistant / on-device Gemini matches against when the
     user issues a voice / NLP request that resolves to our app.

  2. `<shortcut>` — App Shortcuts. Lets the launcher (long-press the app
     icon) and adb fire a specific intent directly. Standalone, works on
     Android 7.1+.

  Today's content is a single **log_food** action — bounded but real (it
  writes the actual food.eaten event Compose call sites would, just with
  defaults when the invoker doesn't supply a parameter). Trigger via the
  launcher long-press shortcut, adb, or Assistant / Gemini matching the
  `actions.intent.CREATE_THING` BII.

  For the modern equivalent that fully replaces this — Gemini's App
  Functions API — see `spec/docs/future-implementations/gemini-app-functions.md`.
  App Functions needs compileSdk 36 + Android 16 runtime + the experimental
  androidx.appfunctions library, none of which is on this branch yet, so the
  capability path here remains the primary Gemini integration until that
  ships.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Capability: maps the `actions.intent.CREATE_THING` BII (extensible
         "create a thing" Built-In Intent — closest match for "log
         something") to LOG_FOOD. Gemini extracts the food name into the
         `thing.name` slot, which becomes our `name` intent extra.

         No grams parameter at the BII level — CREATE_THING doesn't have a
         "quantity" slot, so the handler defaults to 100 g when Gemini is
         the trigger. adb + future custom BIIs can pass an explicit grams. -->
    <capability android:name="actions.intent.CREATE_THING">
        <intent
            android:action="com.ohd.connect.action.LOG_FOOD"
            android:targetPackage="com.ohd.connect"
            android:targetClass="com.ohd.connect.MainActivity">
            <parameter
                android:name="thing.name"
                android:key="name" />
        </intent>
    </capability>

    <!-- Static shortcut: launcher long-press / adb entry point that fires
         the same intent. With no extras supplied here, the handler uses
         its defaults (`Quick log`, 100 g) so even the unparameterised path
         lands a real food event. -->
    <shortcut
        android:shortcutId="log_food_quick"
        android:enabled="true"
        android:shortcutShortLabel="@string/shortcut_log_food_short"
        android:shortcutLongLabel="@string/shortcut_log_food_long">
        <intent
            android:action="com.ohd.connect.action.LOG_FOOD"
            android:targetPackage="com.ohd.connect"
            android:targetClass="com.ohd.connect.MainActivity" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>

</shortcuts>
