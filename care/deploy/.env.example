# OHD Care — example environment file. Copy to .env and fill in real values.
# .env should be 0600 (owner-only) and never committed.

# The operator's domain. DNS A/AAAA records point here; Caddy auto-provisions TLS.
OHD_CARE_DOMAIN=care.your-clinic.example

# Operator OIDC — the clinic's identity provider.
# v0.1 defaults to Google Workspace / Microsoft 365 / Authentik / Keycloak.
OIDC_ISSUER=https://accounts.google.com
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# System DB — operator-side state (sessions, grant vault, audit).
# Default: Postgres (matches docker-compose.yml). For solo deployments swap to
# SQLite by setting CARE_SYSTEM_DB=sqlite:///var/lib/care/system.db and removing
# the postgres service.
CARE_SYSTEM_DB=postgres://care:${POSTGRES_PASSWORD}@postgres:5432/care_system
POSTGRES_PASSWORD=

# Grant-token KMS posture.
#   passphrase     — PBKDF2 from a local key file (solo / small-clinic default)
#   aws-kms        — AWS KMS (cloud Care; need AWS_REGION + IAM creds)
#   gcp-kms        — GCP KMS (cloud Care; need GOOGLE_APPLICATION_CREDENTIALS)
#   vault-transit  — HashiCorp Vault Transit
CARE_KMS_BACKEND=passphrase

# Privacy posture for the Care MCP. When true, no PHI leaves to external LLMs.
# Deployments running on cloud LLMs typically set this to false; ones running on
# self-hosted models keep it true.
CARE_NO_PHI_TO_EXTERNAL_LLMS=true
