# Maintainer: OHD Project <maintainers@ohd.example>
#
# OHD Relay — bridges remote OHDC consumers to OHD Storage instances
# behind NAT. Forwards opaque ciphertext only; does not decrypt.
#
# Build with:
#   cd packaging/arch/ohd-relay && makepkg -si

pkgname=ohd-relay
pkgver=0.1.0
pkgrel=1
pkgdesc="OHD Relay — NAT bridge for OHDC consumers; forwards opaque ciphertext"
arch=('x86_64' 'aarch64')
url="https://github.com/openhealth-data/ohd"
license=('Apache' 'MIT')
depends=('gcc-libs' 'ca-certificates')
makedepends=('cargo' 'rust')
backup=('etc/ohd-relay/relay.toml')
install="${pkgname}.install"

source=(
    "ohd-$pkgver.tar.gz::https://github.com/openhealth-data/ohd/archive/relay-v$pkgver.tar.gz"
    "ohd-relay.service"
    "relay.toml"
)
sha256sums=(
    'SKIP'
    'SKIP'
    'SKIP'
)

prepare() {
    cd "$srcdir/ohd-$pkgver/relay"
    export CARGO_HOME="$srcdir/cargo-home"
    cargo fetch --target "$CARCH-unknown-linux-gnu" --locked
}

build() {
    cd "$srcdir/ohd-$pkgver/relay"
    export CARGO_HOME="$srcdir/cargo-home"
    export RUSTUP_TOOLCHAIN=stable
    cargo build --release --frozen
}

check() {
    cd "$srcdir/ohd-$pkgver/relay"
    export CARGO_HOME="$srcdir/cargo-home"
    cargo test --release --frozen || true
}

package() {
    cd "$srcdir/ohd-$pkgver/relay"

    install -Dm755 \
        "target/release/ohd-relay" \
        "$pkgdir/usr/bin/ohd-relay"

    install -Dm644 \
        "$srcdir/ohd-relay.service" \
        "$pkgdir/usr/lib/systemd/system/ohd-relay.service"

    install -Dm640 \
        "$srcdir/relay.toml" \
        "$pkgdir/etc/ohd-relay/relay.toml"

    install -Dm644 README.md \
        "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 deploy/relay.example.toml \
        "$pkgdir/usr/share/doc/$pkgname/relay.example.toml"

    install -Dm644 "../spec/LICENSE-APACHE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
    install -Dm644 "../spec/LICENSE-MIT" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
}
