# OHD demo deployment — single-box layout on Hetzner ARM.
#
# Apex `ohd.dev` serves the static landing page from /srv/ohd-landing.
# Subdomains reverse-proxy to the OHD storage + relay containers.
# `openhealthdata.org` 301-redirects to ohd.dev.
#
# Auto-TLS via Let's Encrypt (HTTP-01 challenge over :80). DNS must point
# at this server BEFORE first start, otherwise Caddy will retry until cert
# issuance succeeds.

# ---- ohd.dev ---------------------------------------------------------------
ohd.dev, www.ohd.dev {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer-when-downgrade
        Permissions-Policy "interest-cohort=()"
    }

    # APK + release artifacts.
    # File served from the `caddy` container's /srv/ohd-downloads (mounted
    # read-only from /var/www/ohd-downloads on the host — see compose).
    handle /downloads/* {
        root * /srv/ohd-downloads
        uri strip_prefix /downloads
        @apk path *.apk
        header @apk Content-Type "application/vnd.android.package-archive"
        header @apk Content-Disposition "attachment"
        file_server
    }

    # Static landing page. Index.html + styles.css + theme.js + /public/*.
    handle {
        root * /srv/ohd-landing
        file_server
    }
}

# ---- storage.ohd.dev ------------------------------------------------------
# OHD Storage server. HTTP/2 over Caddy with HTTP/3 advertised by default.
storage.ohd.dev {
    encode gzip zstd
    reverse_proxy ohd-storage:8443 {
        transport http {
            versions h2c
        }
    }
}

# ---- relay.ohd.dev --------------------------------------------------------
# OHD Relay HTTP/REST endpoints. The raw QUIC tunnel uses a separate UDP
# port (9001) which is opened directly to the host (see compose mapping +
# UFW rules in DEPLOYMENT.md), bypassing Caddy.
relay.ohd.dev {
    encode gzip zstd
    # No h2c transport override: the consumer-attach endpoint
    # (/v1/attach/<rendezvous_id>) is a WebSocket and needs HTTP/1.1 to the
    # upstream — forcing h2c 502s the upgrade handshake.
    reverse_proxy ohd-relay:8443
}

# ---- api.ohd.dev ----------------------------------------------------------
# OHD SaaS — account / plan / billing. Tiny axum service (see saas/SPEC.md).
# Also proxies the OpenFoodFacts barcode lookup so the Android scanner can
# go through us first (lower-latency + we'll cache once traffic justifies).
api.ohd.dev {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
    }

    # SaaS account routes.
    handle /v1/account* {
        reverse_proxy ohd-saas:8444
    }
    handle /healthz {
        reverse_proxy ohd-saas:8444
    }

    # OpenFoodFacts pass-through. Trims the prefix so /v1/openfoodfacts/<bc>
    # hits OFF's `/api/v2/product/<bc>.json` and search.pl mirrors the
    # generic CGI surface. Both are GET-only.
    handle /v1/openfoodfacts/search {
        uri replace /v1/openfoodfacts/search /cgi/search.pl
        reverse_proxy https://world.openfoodfacts.org {
            header_up Host world.openfoodfacts.org
        }
    }
    handle /v1/openfoodfacts/* {
        uri replace /v1/openfoodfacts/ /api/v2/product/
        # OFF expects `<barcode>.json` — clients pass the bare barcode, we
        # append the suffix here.
        @json path_regexp barcode_id ^/api/v2/product/([^/]+)$
        rewrite @json /api/v2/product/{re.barcode_id.1}.json
        reverse_proxy https://world.openfoodfacts.org {
            header_up Host world.openfoodfacts.org
        }
    }
}

# ---- mcp.ohd.dev ----------------------------------------------------------
# OHD MCP surface — JSON-RPC 2.0 over `/mcp` on the storage server. Same
# bearer-auth as the OHDC connectrpc surface; per-user data sits behind
# the same token. The standalone `ohd-mcp-rs` container was retired once
# storage-server grew its own `/mcp` route (no second daemon, no
# duplicate dispatcher).
mcp.ohd.dev {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
    }

    reverse_proxy ohd-storage:8443 {
        transport http {
            versions h2c
        }
    }
}

# ---- cord.ohd.dev ---------------------------------------------------------
# OHD CORD — the conversational agent web service. Backed by the ohd-cord
# container, which only runs under the `cord` compose profile. See
# cord/SPEC.md.
cord.ohd.dev {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
    }

    reverse_proxy ohd-cord:8446
}

# ---- accounts.ohd.dev -----------------------------------------------------
# OHD Identity — the OpenID Connect provider. Backed by the ohd-idp
# container, which only runs under the `idp` compose profile. Serves the
# OIDC discovery document, JWKS, and (later phases) the authorize/token
# flow + login UI. See idp/SPEC.md.
accounts.ohd.dev {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer
    }

    reverse_proxy ohd-idp:8447
}

# ---- openhealthdata.org → ohd.dev -----------------------------------------
openhealthdata.org, www.openhealthdata.org {
    redir https://ohd.dev{uri} 301
}
