# Copy to .env and fill in for your deployment.
# DO NOT commit the populated .env.

# The operator's domain. Caddy issues certs for relay.<domain> + dispatch.<domain>.
OPERATOR_DOMAIN=ems-example.org

# Email used for ACME registration with Let's Encrypt.
OPERATOR_ADMIN_EMAIL=ops@ems-example.org

# Operator label shown to patients in the break-glass dialog.
# Mirrored from the org cert's CN. Must match the cert's subject.
OPERATOR_LABEL=EMS Example Region

# OIDC issuer URL of OHD's emergency-authority OIDC provider — used by the
# relay's daemon to obtain OIDC tokens before calling Fulcio for cert refresh.
AUTHORITY_OIDC_ISSUER=https://auth.openhealthdata.org/emergency

# Fulcio instance URL — the OHD-operated CA that issues 24h authority certs.
FULCIO_URL=https://fulcio.openhealthdata.org

# Operator's own IdP — used by paramedic tablets and the dispatch console
# for responder authentication (clinic SSO / Okta / Keycloak / etc.).
OPERATOR_IDP_ISSUER=https://sso.ems-example.org/

# Postgres password for the operator records DB.
# In production, store in a secrets manager and inject; do not store at rest.
POSTGRES_PASSWORD=replace-me-with-a-strong-random-password
