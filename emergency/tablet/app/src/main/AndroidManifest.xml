<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      OHD Emergency paramedic tablet permissions.

      BLE patient discovery (Android 12+):
        - BLUETOOTH_SCAN with `neverForLocation`: scan for the OHD beacon
          service UUID. We explicitly disclaim location use so the OS
          does NOT prompt the user with the "share location" affordance —
          paramedics scanning a patient's phone don't need GPS, and
          requesting it would slow shift-in.
        - BLUETOOTH_CONNECT: the NFC/QR fallback flows may need a
          short-lived BLE leg post-discovery to exchange the request.

      BLE patient discovery (pre-Android 12):
        - BLUETOOTH, BLUETOOTH_ADMIN: legacy permissions for older
          minSdk targets (kept here for the rugged-tablet long-tail).
        - ACCESS_FINE_LOCATION: pre-Android 12 BLE scan implies location.
          Capped at maxSdkVersion=30 so Android 12+ uses the
          neverForLocation path.

      Internet + foreground service:
        - INTERNET: OHDC over HTTP/3 to the operator's relay.
        - FOREGROUND_SERVICE / FOREGROUND_SERVICE_CONNECTED_DEVICE: keep
          the active-case cache + intervention queue alive while the
          tablet is on a long ride or in a dead-zone gap. The actual
          service is not declared in this v0 manifest — it lands
          alongside the offline-queue worker.

      Wake lock:
        - WAKE_LOCK: keep the screen alive during an active case so the
          paramedic doesn't lose the patient view mid-intervention.

      Notifications + biometric:
        - POST_NOTIFICATIONS: case-state notifications (handoff success,
          grant approved, queue flush complete). Auto-granted below 33.
        - USE_BIOMETRIC: panic-logout / shift-in unlock via BiometricPrompt.

      What we deliberately DON'T request:
        - ACCESS_BACKGROUND_LOCATION — paramedic shifts are foregrounded.
        - READ_PHONE_STATE — the tablet is not a phone, it's a fleet device.
        - CAMERA — QR fallback for discovery is v0.x; permission lands
          alongside the actual scanner.
    -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="30" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:targetApi="34" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"
        tools:targetApi="33" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <application
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        tools:targetApi="33">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.Material.NoActionBar"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode"
            android:screenOrientation="sensorLandscape">
            <!--
              `screenOrientation=sensorLandscape` defaults the tablet to
              landscape (10" form factor primary, dashboard in the
              ambulance). Phone-portrait fallback is acceptable per the
              brief; paramedics carrying a personal phone get a usable
              UI without rotating to landscape. Material3's adaptive
              layouts handle the breakpoint.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Foreground service for active-case cache + offline write queue
          lands alongside the real implementation:
            <service android:name=".service.CaseSessionService"
                     android:foregroundServiceType="connectedDevice"
                     android:exported="false" />
          Not in v0 — the case vault is in-memory only.
        -->
    </application>
</manifest>
